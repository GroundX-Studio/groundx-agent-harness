# GroundX credentials — required by templates/run_extraction.py
GROUNDX_API_KEY=YOUR_API_KEY
GROUNDX_BASE_URL=https://api.groundx.ai/api

# Extraction model — used by templates/extract.py for the workflow engine config.
# These match the warner-agents production defaults; override per customer if a
# specific model has produced better accuracy on a given document type.
EXTRACT_MODEL_ID=gpt-5-mini
EXTRACT_MODEL_REASONING=high
EXTRACT_MODEL_SERVICE=openai

# Optional: re-use a specific document_id for a re-extraction without re-ingest
# DOCUMENT_ID=
